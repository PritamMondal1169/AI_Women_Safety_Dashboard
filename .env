# ============================================================
# Women Safety Product — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Camera -----
CAMERA_SOURCE=0                    # 0 = default webcam | RTSP URL | video file path
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
CAMERA_RECONNECT_DELAY=3           # seconds before auto-reconnect attempt
CAMERA_MAX_RECONNECT=10            # max consecutive reconnect attempts

# ----- Model -----
MODEL_PATH=models/yolov8n-pose.pt     # YOLOv8 nano pose
MODEL_CONFIDENCE=0.55              # YOLO detection confidence (raised to filter background)
MODEL_IOU=0.5                      # YOLO NMS IoU threshold
MODEL_DEVICE=cpu                  # cpu | cuda | mps
MODEL_IMGSZ=640                    # inference resolution (square)
EXPORT_ONNX=false                  # export ONNX on startup

# ----- Tracking (BoT-SORT via ultralytics) -----
TRACKER_CONFIG=botsort.yaml        # botsort.yaml | bytetrack.yaml
TRACKER_PERSIST=true               # keep tracker state across frames

# ----- Threat Engine -----
THREAT_MODEL_PATH=models/threat_xgb.json   # XGBoost model (trained offline)
THREAT_LOW=0.22                    # score >= this → LOW threat
THREAT_MEDIUM=0.44                 # score >= this → MEDIUM threat
THREAT_HIGH=0.62                   # score >= this → HIGH threat
THREAT_SUSTAINED_FRAMES=8         # only gates escalation to HIGH (reduced from 15)
THREAT_MIN_GROUP_SIZE=2            # min persons in scene to trigger group analysis

# ----- Interaction Analysis -----
ENABLE_INTERACTION_ANALYSIS=true   # enable pairwise pose interaction analyzer
INTERACTION_DISTANCE_THRESHOLD=0.25 # max distance (fraction of diagonal) to analyze pair
INTERACTION_BOOST_MAX=0.25          # max boost added to threat score from interaction

# ----- Alerts -----
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP=smtp.gmail.com
ALERT_EMAIL_PORT=587
ALERT_EMAIL_SENDER=your@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_RECEIVER=emergency@example.com
ALERT_SOUND_ENABLED=true           # Windows winsound; no-op on Linux/macOS
ALERT_COOLDOWN=60                  # seconds between repeated alerts for same track

# ----- Location -----
LOCATION_GOOGLE_API_KEY=""
LOCATION_IP_FALLBACK=true          # use ip-api.com when GPS/Maps unavailable

# ----- Dashboard -----
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_MS=100           # Streamlit component refresh interval
LOG_MAX_ROWS=200                   # max alert rows shown in dashboard log tab

# ----- Logging -----
LOG_LEVEL=DEBUG                    # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# ----- Twilio (SMS / Voice / WhatsApp alerts) -----
TWILIO_ENABLED=true               # set true to enable
TWILIO_ACCOUNT_SID=AC33d72c8c985f38b88fb07b40ee663c5d           # from https://console.twilio.com
TWILIO_AUTH_TOKEN=451389cfc991983dc2e45791eb1a34c3
TWILIO_FROM_NUMBER=+17407576857    # your Twilio number (E.164)
TWILIO_TO_NUMBERS=+916295687435  # comma-separated recipient numbers (E.164)

TWILIO_SMS_ENABLED=true
TWILIO_VOICE_ENABLED=true
TWILIO_WHATSAPP_ENABLED=true
TWILIO_WHATSAPP_FROM=whatsapp:+17407576857   # Twilio sandbox default
TWILIO_VOICE_LANGUAGE=en-IN        # en-IN | en-US | en-GB | hi-IN

# Which threat levels trigger each channel
SMS_ON_LEVELS=HIGH,MEDIUM,LOW
CALL_ON_LEVELS=HIGH,MEDIUM
WHATSAPP_ON_LEVELS=HIGH,MEDIUM

# ----- Africa's Talking (free SMS fallback) -----
AFRICASTALKING_ENABLED=false
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_FROM=""


# ─── Twilio (SMS + Voice + WhatsApp) ─────────────────────────────────────────
# Sign up free: https://www.twilio.com/try-twilio
# Free trial gives $15 credit (~1500 SMS or ~750 min calls)
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=AC33d72c8c985f38b88fb07b40ee663c5d
TWILIO_AUTH_TOKEN=451389cfc991983dc2e45791eb1a34c3
TWILIO_FROM_NUMBER=+17407576857      # Your Twilio phone number
TWILIO_TO_NUMBERS=+916295687435       # Alert recipient(s), comma-separated

# SMS
TWILIO_SMS_ENABLED=true

# Voice call (automated TTS call)
TWILIO_VOICE_ENABLED=true
TWILIO_VOICE_LANGUAGE=en-IN           # en-US, en-IN, hi-IN, etc.

# WhatsApp (must enable Twilio WhatsApp sandbox first)
TWILIO_WHATSAPP_ENABLED=true
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number

# ─── Africa's Talking (free SMS fallback) ─────────────────────────────────────
# Sign up free: https://africastalking.com
# Free sandbox for testing, pay-as-you-go for production
AFRICASTALKING_ENABLED=false
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_USERNAME=sandbox       # use 'sandbox' for testing
AFRICASTALKING_FROM=""

# ─── Alert priority settings ─────────────────────────────────────────────────
# Which threat levels trigger which channels
CALL_ON_LEVELS=HIGH,MEDIUM                  # make a call only for HIGH threats
SMS_ON_LEVELS=HIGH,MEDIUM             # send SMS for HIGH and MEDIUM
WHATSAPP_ON_LEVELS=HIGH,MEDIUM,LOW    # WhatsApp for all levels

# ─── Push Notifications ───────────────────────────────────────────────────────

# ntfy.sh — FREE, no account needed, works on Android + iOS + Desktop
# Setup: Install ntfy app → subscribe to your topic → done
# App: https://ntfy.sh (Android/iOS/Web)
# Docs: https://docs.ntfy.sh
NTFY_ENABLED=false
NTFY_TOPIC=women-safety-alerts-CHANGEME   # change to something unique!
NTFY_SERVER=https://ntfy.sh               # or self-hosted: http://your-server:80
NTFY_PRIORITY_HIGH=urgent                 # urgent|high|default|low|min
NTFY_PRIORITY_MEDIUM=high
NTFY_PRIORITY_LOW=default
NTFY_ACCESS_TOKEN=""

# Firebase Cloud Messaging (FCM) — FREE, requires Google account + app
# Setup: https://console.firebase.google.com
# Use this if you're building a custom Android/iOS app
FCM_ENABLED=false
FCM_SERVER_KEY=""
FCM_DEVICE_TOKENS=""

# Pushover — $5 one-time app purchase, very reliable
# https://pushover.net
PUSHOVER_ENABLED=false
PUSHOVER_APP_TOKEN=""
PUSHOVER_USER_KEY=""
